PORT=3001
HOST=127.0.0.1
TRUST_PROXY=0
CORS_ORIGINS=http://localhost:3000
# Server-side only. Never prefix this with NEXT_PUBLIC or commit a real key.
OPENAI_API_KEY=sk-proj-replace-me
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2
AWS_REGION=ap-south-1
# Keep false unless this is a dedicated, tagged sandbox AWS account.
AWS_ENABLED=false
AWS_VPC_SUBNET_IDS=subnet-xxxxxxxx,subnet-yyyyyyyy
AWS_SECURITY_GROUP_ID=sg-xxxxxxxx
AWS_EC2_AMI_ID=ami-xxxxxxxxxxxxxxxxx
AWS_EC2_INSTANCE_TYPE=t3.micro
AWS_TARGET_PORT=80
AWS_TARGET_HEALTH_PATH=/health
AWS_RESOURCE_TTL_MINUTES=20
SESSION_TTL_MINUTES=20
# Required for every endpoint except /api/health. Use a high-entropy value.
API_KEYS=replace-with-a-long-random-secret
# Required in production. PostgreSQL must enforce TLS in its connection URL.
DATABASE_URL=postgresql://bbf:change-me@localhost:5432/build_break_fix?sslmode=disable
