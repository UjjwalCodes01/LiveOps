# --- Server ---
NODE_ENV=development
# Backend listen port. Intentionally different from the frontend's default
# dev port (3000, see CORS_ORIGINS below) so both can run locally at once.
# On Render, leave PORT unset — Render injects its own and the app already
# reads it.
PORT=4000
# 0.0.0.0 so the app is reachable from outside its container/host, not just
# from within it — required on Render and any other PaaS/container
# platform. Only override to 127.0.0.1 for a deliberately loopback-only
# local setup.
HOST=0.0.0.0
# Number of trusted reverse-proxy hops in front of this server (Express
# "trust proxy" setting). Keep 0 for direct/local access; set to 1 on
# Render (and behind any single load balancer/reverse proxy) so req.ip and
# rate limiting use the real client IP from X-Forwarded-For instead of the
# proxy's.
TRUST_PROXY=0

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/build_break_fix
# Managed Postgres (Render, Supabase, RDS) needs this set to true, or the
# connection fails outright — see DATABASE_SSL in
# src/config/configuration.ts for why. Leave false for a local/self-hosted
# Postgres with no TLS configured (e.g. the docker-compose.yml in this repo).
DATABASE_SSL=false

# --- Authentication ---
# Comma-separated list of accepted x-api-key values.
API_KEYS=generate-a-random-local-api-key

# --- OpenAI (agent orchestration) ---
# Set OPENAI_ENABLED=false to run the agent deterministically with NO OpenAI
# calls at all — every phase uses its verified action with clean narration,
# no API key or credits required, and none of the "AI unavailable" retry
# noise. The full build/break/fix loop still runs on real AWS. Leave it true
# (or unset) to use live LLM reasoning, which needs a funded OPENAI_API_KEY.
OPENAI_ENABLED=true
OPENAI_API_KEY=replace-with-your-server-side-openai-key
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2

# --- CORS / WebSocket origins ---
# Comma-separated list of allowed frontend origins (HTTP CORS and the
# Socket.IO /events gateway both use this). Entries may include a single
# `*` wildcard per origin — e.g. https://*.vercel.app matches every Vercel
# preview deployment subdomain, so you don't have to list each one by hand.
# For a production Vercel frontend, include both the stable production
# domain and a preview wildcard:
#   CORS_ORIGINS=https://your-app.vercel.app,https://*.vercel.app
CORS_ORIGINS=http://localhost:3000

# --- Session lifecycle ---
# Minutes of inactivity before an unfinished session (not completed/failed)
# is automatically expired and its AWS resources torn down.
SESSION_TTL_MINUTES=20
# Days a completed/failed session (and its event log) is kept before being
# hard-deleted from Postgres, so storage doesn't grow unbounded.
SESSION_RETENTION_DAYS=14

# --- AWS sandbox ---
AWS_ENABLED=false
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012
AWS_VPC_ID=vpc-xxxxxxxx
AWS_VPC_SUBNET_IDS=subnet-xxxxxxxx,subnet-yyyyyyyy
AWS_SECURITY_GROUP_ID=sg-xxxxxxxx
AWS_EC2_AMI_ID=ami-xxxxxxxxxxxxxxxxx
AWS_EC2_INSTANCE_TYPE=t3.micro
AWS_TARGET_PORT=80
AWS_TARGET_HEALTH_PATH=/health
# Minutes after creation before tagged demo AWS resources (ALB, target
# group, EC2 targets) are force-deleted by the cleanup cron, regardless of
# session state.
AWS_RESOURCE_TTL_MINUTES=20

# Required whenever this app doesn't run on AWS itself — local dev, Render,
# or any other non-AWS host all need explicit credentials here, since
# there's no EC2/ECS instance role to fall back on. If you deploy this
# backend ONTO AWS (ECS Fargate, EC2) instead, use a task/instance role and
# leave these unset — the AWS SDK's default credential chain finds it
# automatically. Never commit real values.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# --- Tests ---
RUN_AWS_INTEGRATION_TESTS=false
