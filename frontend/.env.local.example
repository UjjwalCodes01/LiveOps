# Copy to .env.local (already gitignored) and fill in real values.
# Never commit .env.local.

# Base URL of the NestJS backend's REST API (includes the /api prefix).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Base origin of the backend's Socket.IO server (no /api prefix, no
# namespace — the /events namespace is appended in lib/socket.ts).
NEXT_PUBLIC_WS_URL=http://localhost:4000

# Must match one of the comma-separated values in the backend's API_KEYS.
# This ships to the browser (NEXT_PUBLIC_) by design — see the frontend
# build plan for why: the Socket.IO handshake already requires it
# client-side, so there's no meaningful way to keep it server-only without
# a bigger backend redesign. It's a shared demo gate, not a user secret;
# the per-session accessToken (minted server-side, stored only in this
# browser) is what actually protects a given session's data.
NEXT_PUBLIC_API_KEY=generate-a-random-local-api-key
